# =============================================================================
# Data Compare v2 — environment variables
# Copy to .env at the repo root before running docker compose
# =============================================================================

# --- Postgres ---
POSTGRES_USER=datacompare
POSTGRES_PASSWORD=changeme_in_prod
POSTGRES_DB=datacompare
POSTGRES_PORT=5432

# Connection string used by the API (inside Docker network = host "postgres")
DATABASE_URL=postgresql://datacompare:changeme_in_prod@postgres:5432/datacompare?schema=public

# --- API ---
API_PORT=3001
JWT_SECRET=replace_with_64_byte_random_secret
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:3000,http://172.16.0.140:3000

# Where uploaded Excel/XML files land (mounted volume in Docker)
UPLOAD_DIR=/var/data-compare/uploads
MAX_UPLOAD_MB=50

# --- Web ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Logging / Observability ---
LOG_LEVEL=info
NODE_ENV=production
